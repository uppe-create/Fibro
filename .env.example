# Local credential login for development/MVP.
# Important: any VITE_* value is bundled into the browser. For real production,
# move authentication to Supabase Auth or a trusted backend before applying the
# strict RLS hardening script.
VITE_LOCAL_LOGIN_USERNAME="usuario_local"
VITE_LOCAL_LOGIN_PASSWORD_HASH="sha256_da_senha"
VITE_LOCAL_LOGIN_ROLE="admin"
# Optional multi-user format:
# VITE_LOCAL_USERS_JSON='[{"username":"admin","passwordHash":"sha256","role":"admin","name":"ADMIN"},{"username":"atendente","passwordHash":"sha256","role":"attendant","name":"ATENDENTE"},{"username":"consulta","passwordHash":"sha256","role":"viewer","name":"CONSULTA"}]'
VITE_LOGIN_MAX_ATTEMPTS="5"
VITE_LOGIN_LOCKOUT_MINUTES="15"
VITE_SESSION_IDLE_TIMEOUT_MINUTES="20"
VITE_SESSION_MAX_DURATION_HOURS="12"
VITE_APP_VERSION="1.0.0"

# Supabase (required after migration)
VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Public app URL used in QR Codes. In production, use the Firebase Hosting URL
# or custom domain, for example: https://cipf.ipero.com
VITE_APP_URL="http://localhost:5173"
